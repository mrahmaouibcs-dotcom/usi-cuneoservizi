# === Variabili d'ambiente di PRODUZIONE (VPS Aruba) ===
# Copiare questo file in ".env" NELLA CARTELLA DELL'APP sul server e
# compilare i valori reali. Poi:  chmod 600 .env
#
# NB: ".env" non finisce mai su GitHub (è in .gitignore): i segreti restano solo sul server.

# --- Database PostgreSQL locale sulla VPS ---
# Sostituisci LA_TUA_PASSWORD_DB con la password scelta in fase di creazione del DB.
DATABASE_URL="postgresql://usi:LA_TUA_PASSWORD_DB@localhost:5432/usi?schema=public"

# --- Area Admin (/it/admin) ---
# METTI UNA PASSWORD ROBUSTA (diversa da quella di default del codice).
ADMIN_PASSWORD="cambia-questa-password"

# --- Email SMTP (casella Aruba del dominio) — per le conferme di prenotazione ---
SMTP_HOST="smtps.aruba.it"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="info@usi-cuneoservizi.it"
SMTP_PASS="password-della-casella-email"
MAIL_FROM="USI - CUNEOServizi <info@usi-cuneoservizi.it>"
MAIL_OFFICE="info@usi-cuneoservizi.it"
